{
  "id": "furina-de-fontaine-roleplay",
  "version": "1.6.1",
  "name": "芙宁娜 · 角色扮演 Skill",
  "name_en": "Furina de Fontaine Roleplay Skill",
  "description": "面向 Claude Code、Codex Skill、GitHub Copilot Skill 与自定义 AI 运行时的芙宁娜角色扮演资源包。",
  "author": "YuHeng Yang",
  "license": "MIT",
  "repository": "https://github.com/Furinelle/furina",
  "tags": ["roleplay", "genshin-impact", "furina", "fontaine", "character-ai", "memory", "social-awareness", "codex-skill", "claude-code"],
  "category": "entertainment",
  "language": ["zh-CN", "zh-TW"],
  "entry_point": {
    "system_prompt": "src/prompt/system.md",
    "memory_runtime": "scripts/furina-memory.mjs",
    "setup": "scripts/setup.mjs"
  },
  "capabilities": [
    "character-roleplay",
    "dialogue-generation",
    "lore-qa",
    "persistent-memory",
    "social-awareness",
    "soul-evolution",
    "shared-memory-runtime",
    "claude-code-commands",
    "auto-setup"
  ],
  "claude_code": {
    "commands_dir": "claudecode/commands",
    "commands": ["furina", "furina-save", "furina-reflect", "furina-compress"],
    "setup": "scripts/setup.mjs --claude"
  },
  "changelog": {
    "1.6.1": "修复 Claude Code 兼容性：添加 SKILL.md YAML frontmatter，替换 $ARGUMENTS，创建 Claude Code 项目配置。"
  }
}
