{
  "strategy": "online-first-with-optional-local-cache",
  "default_source": "bwiki-online",
  "fallback_source": null,
  "fallback_when": "No automatic fallback by default. Use --source genshin-story with GENSHIN_STORY_ROOT, --root, or a sibling genshinstory-cache checkout for local cache lookup.",
  "sources": [
    {
      "id": "bwiki-online",
      "type": "mediawiki_api",
      "description": "Online 原神WIKI_BWIKI MediaWiki API.",
      "api": "https://wiki.biligame.com/ys/api.php",
      "page": "https://wiki.biligame.com/ys/",
      "enabled": true
    },
    {
      "id": "genshin-story",
      "type": "local_markdown",
      "description": "Local clone of kawayiYokami/GenshinStory generated Genshin Impact Markdown docs.",
      "cache_role": "optional-local-cache",
      "env": "GENSHIN_STORY_ROOT",
      "root": "../genshinstory-cache",
      "docs": "web/docs-site/public/domains/gi/docs",
      "generated_docs": "../genshinstory-cache/web/docs-site/public/domains/gi/docs",
      "enabled": true
    }
  ]
}
