{
  "strategy": "local-first-with-online-fallback",
  "default_source": "genshin-story",
  "fallback_source": "bwiki-online",
  "fallback_when": "Use bwiki-online only when the local GenshinStory cache is unavailable or returns fewer search results than requested.",
  "sources": [
    {
      "id": "bwiki-online",
      "type": "mediawiki_api",
      "description": "Online 原神WIKI_BWIKI MediaWiki API.",
      "api": "https://wiki.biligame.com/ys/api.php",
      "page": "https://wiki.biligame.com/ys/",
      "enabled": true
    },
    {
      "id": "genshin-story",
      "type": "local_markdown",
      "description": "Local clone of kawayiYokami/GenshinStory generated Genshin Impact Markdown docs.",
      "cache_role": "primary-local-cache",
      "env": "GENSHIN_STORY_ROOT",
      "root": "vendor/GenshinStory",
      "docs": "web/docs-site/public/domains/gi/docs",
      "generated_docs": "vendor/GenshinStory/web/docs-site/public/domains/gi/docs",
      "enabled": true
    }
  ]
}
